# =============================================================================
# DigitalOcean Deploy Agent — Configuration
# Copy this file to .env and fill in the values, then run: ./deploy/agent.sh
# =============================================================================

# REQUIRED — DigitalOcean API token (Read/Write)
# Create at: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_ACCESS_TOKEN=

# DEPLOY STRATEGY: "github" or "registry"
DEPLOY_STRATEGY=github

# --- GitHub strategy ---
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=

# One-time: connect GitHub to DigitalOcean at
# https://cloud.digitalocean.com/account/applications/github

# --- Registry strategy ---
DO_REGISTRY_NAME=shadow-llm-proxy-registry

# --- App Platform settings (optional) ---
DO_APP_NAME=shadow-llm-proxy
DO_REGION=nyc
DO_APP_ID=

# --- Runtime (optional) ---
LLM_SHADOW_ENABLED=true

# Optional: managed Redis cluster for multi-instance cluster-wide metrics.
# Create at https://cloud.digitalocean.com/databases — then set the cluster name here.
# Leave blank to use in-memory metrics with instance_count: 1 (default).
REDIS_CLUSTER_NAME=
